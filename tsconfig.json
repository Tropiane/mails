{
  "compilerOptions": {
    "target": "ES2021",
    "module": "commonjs",

    "rootDir": "./src",
    "outDir": "./dist",

    "strict": true,

    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,

    "skipLibCheck": true,

    "resolveJsonModule": true,

    "types": ["node"],

    "sourceMap": true
  },

  "include": ["src"],

  "exclude": ["node_modules", "dist"]
}